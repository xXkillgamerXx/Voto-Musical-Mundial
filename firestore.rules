rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in [
          'admin',
          'Admin',
          'ADMIN',
          'superadmin',
          'superAdmin',
          'SuperAdmin',
          'owner',
          'Owner',
          'OWNER',
        ];
    }

    function isAnonymousAuth() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isPositiveVoteAmount(amount) {
      return amount is int && amount > 0 && amount <= 1000;
    }

    function isDailyRewardPointsForDay(day, points) {
      return (day == 1 && points == 10)
        || (day == 2 && points == 15)
        || (day == 3 && points == 20)
        || (day == 4 && points == 25)
        || (day == 5 && points == 30)
        || (day == 6 && points == 40)
        || (day == 7 && points == 50);
    }

    function isSafeOwnerUserUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['points'])
          || request.resource.data.points <= resource.data.points)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['spentPoints'])
          || (request.resource.data.spentPoints is int
            && ((!resource.data.keys().hasAny(['spentPoints'])
              && request.resource.data.spentPoints >= 0)
              || (resource.data.keys().hasAny(['spentPoints'])
                && request.resource.data.spentPoints >= resource.data.spentPoints))));
    }

    function isDailyRewardUserUpdate(userId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'points',
          'lastDailyRewardClaimDate',
          'dailyRewardStreak',
          'dailyRewardStreakDay',
          'dailyRewardClaimedAt',
        ])
        && request.resource.data.lastDailyRewardClaimDate is string
        && request.resource.data.dailyRewardStreak is int
        && request.resource.data.dailyRewardStreak >= 1
        && request.resource.data.dailyRewardStreakDay is int
        && request.resource.data.dailyRewardStreakDay >= 1
        && request.resource.data.dailyRewardStreakDay <= 7
        && (!resource.data.keys().hasAny(['lastDailyRewardClaimDate'])
          || request.resource.data.lastDailyRewardClaimDate != resource.data.lastDailyRewardClaimDate)
        && getAfter(/databases/$(database)/documents/users/$(userId)/dailyRewards/$(request.resource.data.lastDailyRewardClaimDate)).data.userId == userId
        && getAfter(/databases/$(database)/documents/users/$(userId)/dailyRewards/$(request.resource.data.lastDailyRewardClaimDate)).data.streak == request.resource.data.dailyRewardStreak
        && getAfter(/databases/$(database)/documents/users/$(userId)/dailyRewards/$(request.resource.data.lastDailyRewardClaimDate)).data.streakDay == request.resource.data.dailyRewardStreakDay
        && isDailyRewardPointsForDay(
          request.resource.data.dailyRewardStreakDay,
          getAfter(/databases/$(database)/documents/users/$(userId)/dailyRewards/$(request.resource.data.lastDailyRewardClaimDate)).data.points
        )
        && request.resource.data.points == (
          resource.data.points
          + getAfter(/databases/$(database)/documents/users/$(userId)/dailyRewards/$(request.resource.data.lastDailyRewardClaimDate)).data.points
        );
    }

    function isVoteShardCreate() {
      return isSignedIn()
        && !isAnonymousAuth()
        && request.resource.data.keys().hasOnly([
          'pollId',
          'roundId',
          'artistId',
          'shardIndex',
          'votes',
          'updatedAt',
        ])
        && request.resource.data.artistId is string
        && request.resource.data.shardIndex is int
        && isPositiveVoteAmount(request.resource.data.votes);
    }

    function isVoteShardUpdate() {
      return isSignedIn()
        && !isAnonymousAuth()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'updatedAt'])
        && request.resource.data.pollId == resource.data.pollId
        && request.resource.data.roundId == resource.data.roundId
        && request.resource.data.artistId == resource.data.artistId
        && request.resource.data.shardIndex == resource.data.shardIndex
        && isPositiveVoteAmount(request.resource.data.votes - resource.data.votes);
    }

    function isVoteBatchCreate() {
      return isSignedIn()
        && !isAnonymousAuth()
        && request.resource.data.keys().hasOnly([
          'userId',
          'userDisplayName',
          'userPhotoURL',
          'artistId',
          'roundId',
          'amount',
          'pointsSpent',
          'shardIndex',
          'createdAt',
        ])
        && request.resource.data.userId == request.auth.uid
        && isPositiveVoteAmount(request.resource.data.amount)
        && request.resource.data.pointsSpent == request.resource.data.amount;
    }

    function commentCooldownHasPassed(pollId, userId) {
      return !exists(/databases/$(database)/documents/polls/$(pollId)/commentLocks/$(userId))
        || request.time >= get(/databases/$(database)/documents/polls/$(pollId)/commentLocks/$(userId)).data.lastCommentAt + duration.value(5, 'm');
    }

    function isPollCommentCreate(pollId) {
      return isSignedIn()
        && !isAnonymousAuth()
        && request.resource.data.keys().hasOnly([
          'userId',
          'displayName',
          'photoURL',
          'text',
          'gif',
          'createdAt',
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 80
        && request.resource.data.photoURL is string
        && request.resource.data.photoURL.size() <= 500
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 3
        && request.resource.data.text.size() <= 500
        && (!request.resource.data.keys().hasAny(['gif'])
          || (request.resource.data.gif is map
            && request.resource.data.gif.keys().hasOnly([
              'id',
              'url',
              'previewUrl',
              'title',
              'source',
            ])
            && request.resource.data.gif.id is string
            && request.resource.data.gif.id.size() <= 100
            && request.resource.data.gif.url is string
            && request.resource.data.gif.url.size() <= 1000
            && request.resource.data.gif.previewUrl is string
            && request.resource.data.gif.previewUrl.size() <= 1000
            && request.resource.data.gif.title is string
            && request.resource.data.gif.title.size() <= 160
            && request.resource.data.gif.source is string
            && request.resource.data.gif.source.size() <= 20
            && request.resource.data.gif.source == 'giphy'
            && request.resource.data.gif.url.matches('https://.*giphy.com/.*')
            && request.resource.data.gif.previewUrl.matches('https://.*giphy.com/.*')))
        && request.resource.data.createdAt == request.time
        && (isAdmin()
          || (getAfter(/databases/$(database)/documents/polls/$(pollId)/commentLocks/$(request.auth.uid)).data.userId == request.auth.uid
            && getAfter(/databases/$(database)/documents/polls/$(pollId)/commentLocks/$(request.auth.uid)).data.lastCommentAt == request.time
            && commentCooldownHasPassed(pollId, request.auth.uid)));
    }

    function isPollCommentLockWrite(pollId, userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'userId',
          'lastCommentAt',
        ])
        && request.resource.data.userId == userId
        && request.resource.data.lastCommentAt == request.time
        && commentCooldownHasPassed(pollId, userId);
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username;
    }

    match /referralCodes/{code} {
      allow get: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.code == code;
      allow update, delete: if isAdmin();
    }

    match /referralSignups/{signupId} {
      allow read: if isAdmin()
        || (isSignedIn()
          && (resource.data.userId == request.auth.uid
            || resource.data.referrerId == request.auth.uid));
      allow write: if false;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && (!request.resource.data.keys().hasAny(['role'])
          || request.resource.data.role == 'user');
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isAdmin()
        || (isOwner(userId)
          && (isSafeOwnerUserUpdate() || isDailyRewardUserUpdate(userId)));

      match /followingArtists/{artistId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /dailyRewards/{claimDate} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly([
            'userId',
            'claimDate',
            'points',
            'streak',
            'streakDay',
            'claimedAt',
          ])
          && request.resource.data.userId == userId
          && request.resource.data.claimDate == claimDate
          && request.resource.data.streak is int
          && request.resource.data.streak >= 1
          && request.resource.data.streakDay is int
          && request.resource.data.streakDay >= 1
          && request.resource.data.streakDay <= 7
          && isDailyRewardPointsForDay(
            request.resource.data.streakDay,
            request.resource.data.points
          );
        allow update, delete: if false;
      }
    }

    match /artists/{artistId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /followers/{userId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /pollCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /missions/{missionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /contestants/{contestantId} {
        allow read: if true;
        allow create, delete: if isAdmin();
        allow update: if isAdmin();
      }

      match /votes/{voteId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && isPositiveVoteAmount(request.resource.data.amount)
          && request.resource.data.pointsSpent == request.resource.data.amount;
      }

      match /voteShards/{shardId} {
        allow read: if true;
        allow create: if isVoteShardCreate();
        allow update: if isVoteShardUpdate();
      }

      match /userVoteBatches/{batchId} {
        allow read: if isAdmin();
        allow create: if isVoteBatchCreate();
      }

      match /anonymousVoteLocks/{lockId} {
        allow read, write: if false;
      }

      match /commentLocks/{userId} {
        allow read, delete: if false;
        allow create, update: if isPollCommentLockWrite(pollId, userId);
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isPollCommentCreate(pollId);
        allow update: if false;
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.userId == request.auth.uid);
      }

      match /publicResults/{resultId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }

      match /adjustments/{adjustmentId} {
        allow read, create, update, delete: if isAdmin();
      }

      match /rounds/{roundId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();

        match /contestants/{contestantId} {
          allow read: if true;
          allow create, delete: if isAdmin();
          allow update: if isAdmin();
        }

        match /voteShards/{shardId} {
          allow read: if true;
          allow create: if isVoteShardCreate();
          allow update: if isVoteShardUpdate();
        }

        match /userVoteBatches/{batchId} {
          allow read: if isAdmin();
          allow create: if isVoteBatchCreate();
        }

        match /publicResults/{resultId} {
          allow read: if true;
          allow create, update, delete: if isAdmin();
        }
      }
    }
  }
}
