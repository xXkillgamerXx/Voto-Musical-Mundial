rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Admin'];
    }

    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.username == username;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && (!request.resource.data.keys().hasAny(['role'])
          || request.resource.data.role == 'user');
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isAdmin()
        || (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));

      match /followingArtists/{artistId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    match /artists/{artistId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /followers/{userId} {
        allow read: if true;
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /pollCategories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /contestants/{contestantId} {
        allow read: if true;
        allow create, delete: if isAdmin();
        allow update: if isAdmin()
          || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'totalVotes'])
            && request.resource.data.votes == resource.data.votes + 1
            && request.resource.data.totalVotes == resource.data.totalVotes + 1);
      }

      match /votes/{voteId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.amount == 1;
      }

      match /adjustments/{adjustmentId} {
        allow read, create, update, delete: if isAdmin();
      }

      match /rounds/{roundId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();

        match /contestants/{contestantId} {
          allow read: if true;
          allow create, delete: if isAdmin();
          allow update: if isAdmin()
            || (isSignedIn()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'totalVotes'])
              && request.resource.data.votes == resource.data.votes + 1
              && request.resource.data.totalVotes == resource.data.totalVotes + 1);
        }
      }
    }
  }
}
