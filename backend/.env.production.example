NODE_ENV=production
PORT=4000

# Dominio(s) del frontend que pueden llamar a la API (CORS). Separados por coma.
APP_ORIGIN=https://votomusicamundial.com,https://www.votomusicamundial.com

# Base de datos: el host es "postgres" (nombre del servicio en docker-compose), NO localhost.
POSTGRES_DB=votomusicamundial
POSTGRES_USER=votomusicamundial
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE_FUERTE
DATABASE_URL=postgresql://votomusicamundial:CAMBIA_ESTA_CLAVE_FUERTE@postgres:5432/votomusicamundial?schema=public

# Redis: el host es "redis" (nombre del servicio en docker-compose).
REDIS_URL=redis://redis:6379

# Secretos JWT: genera valores aleatorios largos (ej: openssl rand -hex 32)
JWT_ACCESS_SECRET=CAMBIA_ESTO
JWT_REFRESH_SECRET=CAMBIA_ESTO
JWT_ANONYMOUS_SECRET=CAMBIA_ESTO
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ANONYMOUS_EXPIRES_IN=365d

GOOGLE_CLIENT_ID=927668152816-gko08hdb5upa01a3psav544t0gf9m1a4.apps.googleusercontent.com

IP_HASH_SALT=CAMBIA_ESTO
DEFAULT_ANONYMOUS_COOLDOWN_MINUTES=60
VOTE_SYNC_BATCH_SIZE=1000

# Cloudflare Turnstile (proteccion anti-bots en votos anonimos).
# La clave secreta NUNCA va en el frontend. La clave del sitio va en VITE_TURNSTILE_SITE_KEY al construir el frontend.
TURNSTILE_SECRET=CAMBIA_ESTO
TURNSTILE_ENABLED=true
